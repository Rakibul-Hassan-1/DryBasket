"use client";

import Link from "next/link";
import { useEffect, useMemo, useState } from "react";
import { useAuth } from "../src/contexts/AuthContext";
import { useCart } from "../src/contexts/CartContext";
import { logAddToCart, logViewItem } from "../src/lib/analytics";
import { getProducts, Product, seedProductsIfEmpty } from "../src/lib/store";

export default function Home() {
  const { user, loading } = useAuth();
  const { addToCart } = useCart();
  const [products, setProducts] = useState<Product[]>([]);
  const [fetching, setFetching] = useState(true);
  const [query, setQuery] = useState("");
  const [error, setError] = useState("");
  const [toastMessage, setToastMessage] = useState("");
  const [showToast, setShowToast] = useState(false);

  useEffect(() => {
    const run = async () => {
      setError("");
      try {
        await seedProductsIfEmpty();
        const data = await getProducts();
        setProducts(data);
      } catch {
        setError("Failed to load products. Please check Firebase rules.");
      } finally {
        setFetching(false);
      }
    };

    run();
  }, []);

  const handleAddToCart = (product: Product) => {
    if (!user) {
      setToastMessage("⚠️ Please login to add items to cart!");
      setShowToast(true);
      setTimeout(() => setShowToast(false), 3000);
      return;
    }

    addToCart(product);

    // Log add to cart event
    logAddToCart(product.id, product.name, product.price);

    setToastMessage(`✓ ${product.name} added to cart!`);
    setShowToast(true);
    setTimeout(() => {
      setShowToast(false);
    }, 3000);
  };

  const filteredProducts = useMemo(() => {
    const normalized = query.toLowerCase().trim();
    if (!normalized) return products;

    return products.filter(
      (product) =>
        product.name.toLowerCase().includes(normalized) ||
        product.category.toLowerCase().includes(normalized),
    );
  }, [products, query]);

  if (loading) {
    return (
      <div className="min-h-screen flex items-center justify-center bg-gradient-to-br from-indigo-500 to-purple-600">
        <div className="text-white text-xl font-semibold">
          Checking session...
        </div>
      </div>
    );
  }

  return (
    <div className="min-h-screen bg-gradient-to-b from-slate-50 to-white">
      {/* Hero Section */}
      <section className="bg-gradient-to-r from-indigo-600 via-purple-600 to-indigo-700 text-white py-12 sm:py-16 lg:py-24">
        <div className="max-w-6xl mx-auto px-3 sm:px-6">
          <div className="grid grid-cols-1 md:grid-cols-2 gap-6 sm:gap-8 items-center">
            <div>
              <div className="inline-block bg-indigo-500 bg-opacity-50 px-3 sm:px-4 py-2 rounded-full text-xs sm:text-sm font-semibold mb-3 sm:mb-4">
                🌾 Premium Quality Assured
              </div>
              <h1 className="text-3xl sm:text-4xl lg:text-5xl font-bold mb-3 sm:mb-4 leading-tight">
                Discover Premium Dry Foods
              </h1>
              <p className="text-base sm:text-lg text-indigo-100 mb-6 sm:mb-8 leading-relaxed">
                Shop authentic, high-quality dry foods directly from trusted
                suppliers. Fresh, healthy, and delivered to your doorstep with
                secure checkout.
              </p>
              <div className="flex gap-3 sm:gap-4 flex-wrap">
                <Link
                  href="#products"
                  className="bg-white text-indigo-600 px-5 sm:px-8 py-2 sm:py-3 rounded-lg font-semibold hover:bg-indigo-50 transition transform hover:scale-105 text-sm sm:text-base"
                >
                  Browse Products
                </Link>
                {!user && (
                  <Link
                    href="/login"
                    className="border-2 border-white text-white px-8 py-3 rounded-lg font-semibold hover:bg-white hover:text-indigo-600 transition"
                  >
                    Sign Up Now
                  </Link>
                )}
              </div>
            </div>
            <div className="hidden md:block text-center">
              <div className="inline-block text-8xl">🛒</div>
            </div>
          </div>
        </div>
      </section>

      {/* Main Section */}
      <section className="max-w-6xl mx-auto px-3 sm:px-6 py-8 sm:py-12">
        {/* Search Header */}
        <div className="mb-8 sm:mb-10">
          <div className="flex items-center justify-between mb-4 sm:mb-6 flex-wrap gap-3 sm:gap-4">
            <div>
              <h2 className="text-2xl sm:text-3xl font-bold text-gray-900">
                Shop Our Collection
              </h2>
              <p className="text-sm sm:text-base text-gray-600 mt-1 sm:mt-2">
                {filteredProducts.length}{" "}
                {filteredProducts.length === 1 ? "product" : "products"} found
              </p>
            </div>
            {user && (
              <div className="text-xs sm:text-sm bg-green-50 text-green-700 px-3 sm:px-4 py-2 rounded-lg border border-green-200 font-medium flex items-center gap-2 whitespace-nowrap">
                <span>✓</span>
                <span className="hidden sm:inline">
                  Logged in as {user.email?.split("@")[0]}
                </span>
                <span className="sm:hidden">Logged in</span>
              </div>
            )}
          </div>

          {/* Search Input */}
          <div className="relative">
            <svg
              className="absolute left-3 sm:left-4 top-3 sm:top-3.5 w-4 sm:w-5 h-4 sm:h-5 text-gray-400"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                strokeLinecap="round"
                strokeLinejoin="round"
                strokeWidth={2}
                d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"
              />
            </svg>
            <input
              type="text"
              value={query}
              onChange={(event) => setQuery(event.target.value)}
              placeholder="Search by name or category (e.g., rice, nuts, dates)..."
              className="w-full border-2 border-gray-300 bg-white rounded-xl pl-12 pr-4 py-3 outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 text-gray-900 font-medium transition"
            />
          </div>
        </div>

        {/* Error Message */}
        {error && (
          <div className="mb-6 rounded-xl bg-red-50 border-2 border-red-200 text-red-700 px-5 py-4 flex items-start gap-3">
            <svg
              className="w-6 h-6 flex-shrink-0 mt-0.5"
              fill="currentColor"
              viewBox="0 0 20 20"
            >
              <path
                fillRule="evenodd"
                d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z"
                clipRule="evenodd"
              />
            </svg>
            <div>
              <p className="font-semibold">Failed to Load Products</p>
              <p className="text-sm mt-1">{error}</p>
            </div>
          </div>
        )}

        {/* Loading State */}
        {fetching ? (
          <div className="grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
            {[1, 2, 3, 4, 5, 6].map((i) => (
              <div
                key={i}
                className="bg-white rounded-xl border border-gray-200 overflow-hidden animate-pulse"
              >
                <div className="h-48 bg-gray-300"></div>
                <div className="p-5 space-y-4">
                  <div className="h-4 bg-gray-300 rounded w-1/3"></div>
                  <div className="h-5 bg-gray-300 rounded w-2/3"></div>
                  <div className="h-4 bg-gray-300 rounded w-full"></div>
                  <div className="flex justify-between pt-2">
                    <div className="h-6 bg-gray-300 rounded w-1/4"></div>
                    <div className="h-4 bg-gray-300 rounded w-1/4"></div>
                  </div>
                </div>
              </div>
            ))}
          </div>
        ) : filteredProducts.length === 0 ? (
          <div className="text-center py-16">
            <svg
              className="w-16 h-16 text-gray-400 mx-auto mb-4"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                strokeLinecap="round"
                strokeLinejoin="round"
                strokeWidth={1.5}
                d="M20 13V6a2 2 0 00-2-2H6a2 2 0 00-2 2v7m16 0v5a2 2 0 01-2 2H6a2 2 0 01-2-2v-5m16 0h-2.586a1 1 0 00-.707.293l-2.414 2.414a1 1 0 01-.707.293h-3.172a1 1 0 01-.707-.293l-2.414-2.414A1 1 0 006.586 13H4"
              />
            </svg>
            <p className="text-gray-600 text-lg font-medium">
              No products found
            </p>
            <p className="text-gray-500 mt-2">
              Try adjusting your search filters
            </p>
          </div>
        ) : (
          <div
            id="products"
            className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6 scroll-mt-16"
          >
            {filteredProducts.map((product) => (
              <article
                key={product.id}
                className="bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm hover:shadow-lg hover:-translate-y-1 transition duration-300 group flex flex-col"
                onMouseEnter={() =>
                  logViewItem(product.id, product.name, product.price)
                }
              >
                {/* Image Container */}
                <div className="relative h-48 overflow-hidden bg-gray-100">
                  <img
                    src={product.imageUrl}
                    alt={product.name}
                    className="w-full h-full object-cover group-hover:scale-110 transition duration-300"
                  />
                  <div className="absolute top-2 sm:top-3 right-2 sm:right-3">
                    <span className="inline-flex items-center gap-1 bg-white text-gray-900 px-2 sm:px-3 py-1 sm:py-1.5 rounded-full text-xs sm:text-sm font-semibold shadow-md">
                      <span className="text-base sm:text-lg">📦</span>
                      <span>{product.stock}</span>
                    </span>
                  </div>

                {/* Content */}
                <div className="p-3 sm:p-5 flex flex-col grow">
                  {/* Category Badge */}
                  <div className="mb-2 sm:mb-3">
                    <span className="inline-flex px-2 sm:px-3 py-1 sm:py-1.5 rounded-full bg-indigo-100 text-indigo-700 text-xs font-bold uppercase tracking-wide">
                      {product.category}
                    </span>
                  </div>

                  {/* Title & Description */}
                  <h3 className="text-base sm:text-lg font-bold text-gray-900 mb-1 sm:mb-2 line-clamp-2">
                    {product.name}
                  </h3>
                  <p className="text-xs sm:text-sm text-gray-600 mb-3 sm:mb-4 line-clamp-2 grow">
                    {product.description}
                  </p>

                  {/* Weight Info */}
                  {product.weight && (
                    <div className="mb-4 pb-4 border-b border-gray-200">
                      <p className="text-xs text-gray-500 uppercase font-semibold tracking-wide">
                        Weight
                      </p>
                      <p className="text-sm font-semibold text-gray-900">
                        {product.weight}
                      </p>
                    </div>
                  )}

                  {/* Price & Stock */}
                  <div className="mb-3 sm:mb-4 flex items-baseline justify-between gap-2">
                    <div>
                      <p className="text-xs text-gray-500 uppercase font-semibold tracking-wide">
                        Price
                      </p>
                      <p className="text-2xl sm:text-3xl font-bold text-indigo-600">
                        ৳{product.price.toLocaleString("bn-BD")}
                      </p>
                    </div>
                    <div className="text-right">
                      <p className="text-xs text-gray-500 uppercase font-semibold tracking-wide">
                        Available
                      </p>
                      <p
                        className={`text-sm sm:text-lg font-bold ${product.stock > 10 ? "text-green-600" : product.stock > 0 ? "text-amber-600" : "text-red-600"}`}
                      >
                        {product.stock > 0
                          ? `${product.stock} left`
                          : "Sold Out"}
                      </p>
                    </div>
                  </div>

                  {/* Button */}
                  {user ? (
                    <button
                      onClick={() => handleAddToCart(product)}
                      disabled={product.stock < 1}
                      className={`w-full py-2 sm:py-3 rounded-lg font-semibold text-sm sm:text-base transition duration-200 flex items-center justify-center gap-2 ${
                        product.stock < 1
                          ? "bg-gray-200 text-gray-500 cursor-not-allowed"
                          : "bg-indigo-600 text-white hover:bg-indigo-700 active:scale-95 shadow-md hover:shadow-lg"
                      }`}
                    >
                      <span>🛒</span>
                      <span className="hidden sm:inline">{product.stock < 1 ? "Out of Stock" : "Add to Cart"}</span>
                      <span className="sm:hidden">{product.stock < 1 ? "Out" : "Add"}</span>
                    </button>
                  ) : (
                    <Link
                      href="/login"
                      className="w-full py-2 sm:py-3 rounded-lg font-semibold text-sm sm:text-base transition duration-200 bg-indigo-600 text-white hover:bg-indigo-700 active:scale-95 shadow-md hover:shadow-lg flex items-center justify-center gap-2"
                    >
                      <span>🔑</span>
                      <span className="hidden sm:inline">Login to Buy</span>
                      <span className="sm:hidden">Login</span>
                    </Link>
                  )}
                </div>
              </article>
            ))}
          </div>
        )}

        {/* Info Section */}
        {!user && (
          <div className="mt-12 sm:mt-16 bg-gradient-to-r from-indigo-50 to-purple-50 border border-indigo-200 rounded-2xl p-6 sm:p-8 md:p-12">
            <div className="grid grid-cols-1 md:grid-cols-3 gap-6 sm:gap-8 mb-6 sm:mb-8">
              <div className="text-center">
                <div className="text-3xl sm:text-4xl mb-2 sm:mb-3">🔒</div>
                <h4 className="font-bold text-gray-900 mb-1 sm:mb-2 text-sm sm:text-base">
                  Secure Checkout
                </h4>
                <p className="text-gray-600 text-xs sm:text-sm">
                  Firebase authentication ensures your account is protected
                </p>
              </div>
              <div className="text-center">
                <div className="text-3xl sm:text-4xl mb-2 sm:mb-3">📦</div>
                <h4 className="font-bold text-gray-900 mb-2">Fast Delivery</h4>
                <p className="text-gray-600 text-sm">
                  Ships within 2-3 business days across Bangladesh
                </p>
              </div>
              <div className="text-center">
                <div className="text-4xl mb-3">✨</div>
                <h4 className="font-bold text-gray-900 mb-2">
                  Premium Quality
                </h4>
                <p className="text-gray-600 text-sm">
                  Hand-selected products from trusted suppliers
                </p>
              </div>
            </div>
            <div className="text-center">
              <p className="text-gray-700 mb-4 font-medium">
                Create an account to start shopping
              </p>
              <Link
                href="/login"
                className="inline-block bg-indigo-600 text-white px-8 py-3 rounded-lg font-semibold hover:bg-indigo-700 transition transform hover:scale-105"
              >
                Create Account Now
              </Link>
            </div>
          </div>
        )}
      </section>

      {/* Toast Notification */}
      {showToast && (
        <div className="fixed bottom-6 right-6 bg-white border-2 border-green-500 text-green-700 px-6 py-4 rounded-xl shadow-2xl font-semibold flex items-center gap-3 animate-pulse max-w-xs z-50">
          <span className="text-2xl">✓</span>
          <span>{toastMessage}</span>
        </div>
      )}
    </div>
  );
}
